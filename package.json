{
  "name": "@traditional-colors/core",
  "version": "0.1.0",
  "description": "Traditional colors from Japan, China, and Europe for popular frameworks - Tailwind CSS, VS Code, Material-UI, and more",
  "keywords": [
    "colors",
    "traditional-colors",
    "japanese-colors",
    "nippon-colors",
    "tailwind",
    "tailwindcss",
    "vscode",
    "material-ui",
    "design-system",
    "color-palette",
    "和色",
    "伝統色"
  ],
  "author": "Traditional Colors Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kako-jun/traditional-colors.git"
  },
  "bugs": {
    "url": "https://github.com/kako-jun/traditional-colors/issues"
  },
  "homepage": "https://github.com/kako-jun/traditional-colors#readme",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./colors": {
      "import": "./dist/colors.js",
      "require": "./dist/colors.cjs",
      "types": "./dist/colors.d.ts"
    }
  },
  "files": [
    "dist",
    "data",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:data && npm run build:generators",
    "build:data": "node scripts/validate-data.js",
    "build:generators": "node generators/build-all.js",
    "build:tailwind": "node generators/tailwind.js",
    "build:vscode": "node generators/vscode.js",
    "build:css": "node generators/css-variables.js",
    "dev": "npm run build -- --watch",
    "test": "vitest",
    "test:ci": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test:ci"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
